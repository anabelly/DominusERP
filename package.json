{
  "name": "sistema",
  "version": "1.0.2",
  "description": "ERP Sistema",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.dominus.erp",
    "productName": "Dominus ERP",
    "directories": {
      "output": "release"
    },
    "files": [
      "**/*",
      "!release/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "dominus.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "anabelly",
        "repo": "DominusERP"
      }
    ]
  }
}